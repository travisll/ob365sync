{
  "name": "obsidian-office365-calendar-sync",
  "version": "0.2.0",
  "description": "Obsidian plugin for two-way Office 365 calendar sync",
  "main": "main.js",
  "homepage": "https://github.com/travisll/ob365sync",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/travisll/ob365sync.git"
  },
  "bugs": {
    "url": "https://github.com/travisll/ob365sync/issues"
  },
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "release": "npm run build && node scripts/release.mjs",
    "test": "vitest run",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
