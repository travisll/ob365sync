  "devDependencies": {
    "@types/node": "^24.6.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.9",
    "obsidian": "^1.8.10",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@azure/msal-node": "^3.8.0"
  }
}
